      "assertions": [
        { "kind": "quote_number", "field": "total", "expected": 13.5 },
        { "kind": "quote_number", "field": "discountTotal", "expected": 6.5 },
        { "kind": "line_total", "sku": "alpha-kit", "expected": 18 }
      ]
    },
