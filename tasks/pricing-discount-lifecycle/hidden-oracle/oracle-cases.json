        { "kind": "line_total", "sku": "thread-cone", "expected": 2.004 },
        { "kind": "quote_number", "field": "subtotal", "expected": 10.02 },
        { "kind": "quote_number", "field": "total", "expected": 6.012 }
      ]
    },
