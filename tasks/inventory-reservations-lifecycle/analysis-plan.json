  "conditions": ["context_only_spec", "feedback_capable_spec"],
  "run_classifications": ["difficulty_probe", "causal_pilot"],
  "primary_metric": "final_checkpoint_pass_rate_delta",
  "secondary_metrics": [
    "regression_count_delta",
    "regression_free_success_by_checkpoint",
    "regression_free_auc"
  ],
  "planned_metrics": [],
  "budget": {
    "max_model_turns": 2,
    "max_feedback_runs": 1
  },
  "model_provider": {
    "provider": "openrouter",
    "model": "mistralai/mistral-small-2603",
    "adapter_id": "openrouter-loop"
  },
  "exclusion_rules": [
    "exclude diagnostic_invalid runs from all aggregate summaries",
    "exclude provider/network validity-flagged runs from primary causal estimates",
    "exclude one-turn or no-feedback-path runs from causal feedback-use evidence",
    "do not pool across compatibility profile changes"
  ],
  "pooling_rules": {
