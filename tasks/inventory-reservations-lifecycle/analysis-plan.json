  "frozen_inputs": [
    "task_version",
    "checkpoint_list",
    "visible_specs",
    "feedback_assets",
    "hidden_oracle",
    "budget",
    "model_provider",
    "exclusion_rules",
    "primary_metric",
    "secondary_metrics",
    "pooling_rules"
  ]
