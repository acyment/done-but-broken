      "hidden_oracle_hash",
      "budget_hash",
      "model_provider_hash",
      "provider_execution_profile_hash",
      "metric_definition_hash"
    ],
    "reject_validity_flags": true,
    "reject_unclassified_runs": true
  },
  "promotion_gates": [
    "local_acceptance_criteria_all_pass",
    "visible_feedback_assets_implemented_and_gated",
    "hidden_oracle_reference_candidate_passes",
    "no_provider_fake_pilot_validates",
    "analysis_plan_sealed_before_provider_run"
