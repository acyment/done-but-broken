{
  "protocol_id": "e1-frontier-consolidated-protocol-v0",
  "status": "draft_pre_l1_l2",
  "run_authorization": "none",
  "condition_ids": ["context_only_spec", "feedback_capable_spec"],
  "editing_protocol": {
    "format": "full_file_replacement",
    "replacement_precedence": ["replacement_blocks", "verification_request", "done_declaration"],
    "claim_qualifier": "under a turn-based, full-file-replacement editing protocol with budgeted verification executions",
    "billing_v2_source_file_loc_cap": 450
  },
  "turn_policy": {
    "max_model_turns_per_checkpoint": 12,
    "zero_valid_blocks_behavior": "no_op_turn_consumes_turn",
    "no_op_notice": "no valid blocks parsed",
    "max_consecutive_no_op_turns": 3,
    "stall_classification": "agent_stalled",
    "agent_stalled_drift_policy": "excluded_from_drift_analysis_counts_as_new_assertion_failure"
  },
  "stall_reporting": {
    "required_table": "per_model_by_arm",
    "protocol_usability_caveat_ratio_threshold": 2,
    "protocol_usability_caveat_min_higher_arm_checkpoint_rate": 0.05,
    "feedback_arm_stalls_more_action": "review_transcripts_for_verification_output_parser_confusion_before_interpreting_model_ability"
  },
  "path_grammar": {
    "platform": "posix_macos_linux_only",
    "regex": "^[A-Za-z0-9._-][A-Za-z0-9._/-]*$",
    "ascii_only": true,
    "relative_only": true,
    "forbid_leading_dash": true,
    "forbid_dot_dot_segment": true,
    "forbid_windows_separator": true,
    "resolution": "resolve_against_workspace_root_then_realpath_prefix_containment_in_scratch"
  },
  "verification_channel": {
    "max_executions_per_checkpoint": 6,
    "timeout_ms": 60000,
    "output_limit_tokens": 4000,
    "truncation": {
      "head_tokens": 2500,
      "tail_tokens": 1500,
      "marker_required": true
    },
    "typescript_command_templates": [
      {
        "template": "bun test scratch/",
        "conditions": ["context_only_spec", "feedback_capable_spec"]
      },
      {
        "template": "bun scratch/<script>.ts",
        "conditions": ["context_only_spec", "feedback_capable_spec"]
      },
      {
        "template": "bun run spec",
        "conditions": ["feedback_capable_spec"]
      },
      {
        "template": "bun run spec -- --cp=<checkpoint>",
        "conditions": ["feedback_capable_spec"]
      }
    ],
    "runtime_bun_args": ["--no-install"],
    "non_whitelisted_command_behavior": "refusal_string_consumes_verification_slot"
  },
  "token_ledger": {
    "debits": ["model_output_tokens", "injected_verification_output_tokens"],
    "provider_reported_usage_is_primary_when_present": true,
    "sealed_estimator_shadow_mode_required": true,
    "estimator_name": "TBD_before_L1_seal",
    "estimator_version": "TBD_before_L1_seal",
    "provider_estimator_sustained_divergence_review_threshold": 0.15,
    "cached_repo_prefix": "recorded_as_cost_statistic_not_checkpoint_budget_debit",
    "cross_provider_note": "token_budgets_are_provider_tokenizer_denominated_compare_arms_within_model"
  },
  "protected_path_integrity": {
    "protected_paths": ["specs/**", "package.json", "bunfig.toml", "tsconfig.json", "bun.lock", "bun.lockb"],
    "hash_at": ["checkpoint_start"],
    "verify_after": ["replacement_application", "verification_execution"],
    "mismatch_classification": "invalid_integrity",
    "defense_in_depth": "chmod_protected_paths_read_only_when_sandbox_supports_it",
    "claim_bearing_guarantee": "post_mutation_hash_check"
  },
  "audit_diff": {
    "model_facing_replacement_output": "applied: <path> (<before_lines> -> <after_lines> lines)",
    "diff_visibility_to_model": "never",
    "include_paths": ["src/", "scratch/", "specs/"],
    "exclude_paths": ["node_modules/", ".git/", "harness_logs/", "coverage/", "bun_cache/", "run_artifacts/"],
    "path_sort": "byte_lexicographic",
    "line_ending_normalization": false,
    "file_mode_changes_recorded": true,
    "binary_file_policy": "hash_pairs_not_textual_hunks",
    "ground_truth": "workspace_snapshots"
  },
  "lockfile_policy": {
    "zero_dependency_boundary": {
      "deps": "none",
      "lockfile": "lockfile_absent_zero_dependency_package"
    },
    "sandbox_setup_if_lockfile_exists": "bun install --frozen-lockfile",
    "fail_closed_from_first_dependency_commit": true,
    "missing_or_stale_lockfile_with_dependencies": "invalid_environment_boundary"
  },
  "l1_shakedown": {
    "required_before_cartcalc": true,
    "scripted_agents": [
      "pure_prose_no_blocks",
      "malformed_unclosed_delimiters",
      "malformed_nested_delimiters",
      "malformed_interleaved_code_fences",
      "single_outer_markdown_fence_valid_blocks",
      "valid_blocks_wrong_precedence",
      "chatty_valid_blocks_buried_in_explanations"
    ],
    "parser_policy": "strip_one_outer_markdown_fence_layer_then_parse",
    "cheap_real_model_no_op_rate_probe_required": true,
    "cheap_model_no_op_rate_iteration_threshold": 0.1
  },
  "step0_sequence": [
    "l0_battery_expanded",
    "l1_build",
    "l1_shakedown_scripted_agents",
    "l2_build",
    "cartcalc_cheap_runs",
    "cartcalc_frontier_context_run",
    "cost_projection",
    "trim_window",
    "billing_v2_seal"
  ],
  "stability_gate": {
    "environments": ["macos_local", "ubuntu_24_container"],
    "same_pinned_bun_version": true,
    "consecutive_green_full_suites_per_environment": 10,
    "quarantined_tests_allowed_without_published_exclusion_list": false,
    "real_clock_sleep_dependency_allowed_in_harness_tests": false
  }
}
